# ──────────────────────────────────────
# ISE ACME Automation - .gitignore
# ──────────────────────────────────────

# Configuration with secrets (use config.example.json as template)
config.json
config.*.json
!config.example.json

# Environment files
.env
.env.*
*.env

# Logs
logs/
*.log

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
.venv/
.env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Docker
.docker/

# Kubernetes secrets (never commit)
*-secret.yaml
*-secrets.yaml

# Certificates and keys (never commit)
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
*.jks
