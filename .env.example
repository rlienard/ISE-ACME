# ──────────────────────────────────────
# ISE ACME Automation - Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────

# Cisco ISE
ISE_HOST=ise-pan.yourdomain.com
ISE_USERNAME=api-admin
ISE_PASSWORD=CHANGE_ME
ISE_ERS_PORT=9060
ISE_OPEN_API_PORT=443

# DigiCert ACME
ACME_DIRECTORY_URL=https://acme.digicert.com/v2/acme/directory/
ACME_KID=CHANGE_ME
ACME_HMAC_KEY=CHANGE_ME

# Certificate
CERT_CN=guest.yourdomain.com
CERT_SAN=guest.yourdomain.com,portal.yourdomain.com
CERT_KEY_TYPE=RSA_2048
PORTAL_GROUP_TAG=Default Portal Certificate Group
CERTIFICATE_MODE=shared
PRIMARY_NODE=ise-psn01.yourdomain.com
RENEWAL_THRESHOLD_DAYS=30

# ISE Nodes (JSON array)
ISE_NODES=[{"name":"ise-psn01.yourdomain.com","role":"PSN","enabled":true},{"name":"ise-psn02.yourdomain.com","role":"PSN","enabled":true}]

# DNS Provider
DNS_PROVIDER=cloudflare
CLOUDFLARE_API_TOKEN=CHANGE_ME
CLOUDFLARE_ZONE_ID=CHANGE_ME

# AWS (if using Route53)
# AWS_HOSTED_ZONE_ID=CHANGE_ME
# AWS_REGION=us-east-1

# Azure (if using Azure DNS)
# AZURE_SUBSCRIPTION_ID=CHANGE_ME
# AZURE_RESOURCE_GROUP=CHANGE_ME
# AZURE_DNS_ZONE_NAME=CHANGE_ME

# Email Notifications
SMTP_SERVER=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USERNAME=alerts@yourdomain.com
SMTP_PASSWORD=CHANGE_ME
ALERT_RECIPIENTS=netadmin@yourdomain.com
